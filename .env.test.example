# Test database — a throwaway local Postgres (docker-compose.test.yml), never Neon.
# Both vars point at the same local instance since there's no PgBouncer involved locally;
# copy this file to .env.test (already gitignored) and these defaults will just work.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/volunteer_ops_test"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/volunteer_ops_test"

# Vitest tests never call Clerk or R2 for real (both are mocked at the module boundary),
# so no keys are needed here. Playwright E2E is different — see tests/e2e/README.md.
