generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SHIFT_LEAD
  VOLUNTEER
  GUEST
}

enum VolunteerStatus {
  ACTIVE
  INACTIVE
}

enum HandlingColor {
  GREEN
  ORANGE
  YELLOW
  BLUE
  RED
}

enum ShiftType {
  AM
  PM
}

enum CheckMethod {
  QR
  SMS
  KIOSK
  PWA_TAP
  WEB_FORM
  ADMIN_ENTRY
  LEGACY_FORM
}

enum AnimalStatus {
  ACTIVE
  ADOPTED
  RETURNED
  DECEASED
  TRANSFERRED
  FOSTER
  PENDING_ADOPTION
}

// V3.md Session 1: SIRE_OF/DAM_OF/SIBLING_OF cover the confirmed real bloodline case
// (Guinness sired Rowan and Shannon); OTHER is the catch-all for anything that doesn't fit
// those three (half-sibling, dam/sire once removed, etc.) rather than growing the enum for
// every rare case — matches CONTEXT.md §3's "hard enums only for a small fixed real-world
// set" guidance, with OTHER as the escape hatch instead of a lookup table (this relationship
// type genuinely is fixed, unlike FeedType/CareType which staff add to over time).
enum RelationType {
  SIRE_OF
  DAM_OF
  SIBLING_OF
  OTHER
}

enum AnimalSex {
  STALLION
  GELDING
  MARE
  COLT
  FILLY
  RIDGLING
  UNKNOWN
}

enum AnimalSpecies {
  HORSE
  DONKEY
  MULE
  MINI_HORSE
  PONY
  CAT
  OTHER
}

enum FeedUnit {
  SCOOP
  FLAKE
  SQUIRT
  POUR
  OTHER
}

enum FeedCategory {
  MAIN_FEED
  HAY
  SUPPLEMENT
  ADDITIVE
}

enum CareCategory {
  MEDICAL
  SEASONAL
  GROOMING
  OTHER
}

enum WeightContext {
  ROUTINE
  ASSESSMENT
}

enum ChatChannelType {
  BROADCAST
  ADMIN
  SHIFT
}

enum ChangeLogAction {
  CREATE
  UPDATE
}

enum LocationType {
  FIELD
  BARN_STALL
  SICK_BAY
  ARENA
  OTHER
}

enum LocationPeriod {
  DAY
  NIGHT
}

enum EventSignupStatus {
  CONFIRMED
  WAITLISTED
  CANCELLED
}

enum FarmSeason {
  STANDARD
  WINTER
}

model Volunteer {
  id                    String                     @id @default(cuid())
  clerkId               String?                    @unique
  name                  String
  email                 String?
  phone                 String?
  emergencyContactName  String?
  emergencyContactPhone String?
  role                  Role                       @default(VOLUNTEER)
  status                VolunteerStatus            @default(ACTIVE)
  tier                  HandlingColor              @default(GREEN)
  tierUpdatedAt         DateTime?
  hireDate              DateTime?
  // V2.md Session 2: the tenure clock for the Green->Orange->Yellow->Blue progression.
  // Deliberately set from the first real CheckIn, not account creation — see
  // checkin/actions.ts. Null until then; computeTiers() (src/lib/tier.ts) treats a null
  // firstShiftDate as zero tenure rather than erroring.
  firstShiftDate        DateTime?
  // Manual human gate for Blue, independent of tenure (CONTEXT.md §6: tenure alone never
  // grants Blue). Set only via releaseBlue() (src/app/volunteers/tier-actions.ts).
  blueReleasedAt        DateTime?
  blueReleasedById      String?
  blueReleasedBy        Volunteer?                 @relation("BlueRelease", fields: [blueReleasedById], references: [id])
  blueReleases          Volunteer[]                @relation("BlueRelease")
  accessValidFrom       DateTime?
  accessValidUntil      DateTime?
  // V2.md Session 4: independent of role — grants event-creation ability to specific people
  // (e.g. Lori) without making them a full ADMIN. ADMIN can always create events regardless
  // of this flag (see requireCanScheduleEvents() in src/app/events/actions.ts).
  canScheduleEvents     Boolean                    @default(false)
  // V2.md Session 5: one code, two presentations — printed/scanned at the shared kiosk
  // tablet, or QR-encoded on the volunteer's own device (src/app/checkin/code/page.tsx).
  // Generated client-side by Prisma's cuid() default, same as every other id in this schema.
  checkInCode           String                     @unique @default(cuid())
  notes                 String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  credentials           CredentialRecord[]
  regularShifts         RegularShiftAssignment[]
  checkIns              CheckIn[]                  @relation("VolunteerCheckIns")
  loggedCheckIns        CheckIn[]                  @relation("LoggedByVolunteer")
  sentMessages          ChatMessage[]
  recordedLocationMoves AnimalLocationAssignment[]
  tagAssignments        VolunteerTagAssignment[]   @relation("VolunteerTagHolder")
  tagsAssigned          VolunteerTagAssignment[]   @relation("VolunteerTagAssignedBy")
  tagsRemoved           VolunteerTagAssignment[]   @relation("VolunteerTagRemovedBy")
  createdEvents         Event[]                    @relation("EventCreatedBy")
  eventWatching         EventWatcher[]
  eventSignups          EventSignup[]
  recordedRelationships AnimalRelationship[]

  @@index([clerkId])
  @@index([role])
  @@index([status])
}

// Covers both vaccinations and compliance/training acknowledgments under one mechanism
// (CONTEXT.md §7). V2.md Session 2's "compliance training" ask (a requirement definition +
// per-volunteer completions with expiration) is exactly this existing shape — extended here
// with the fields that ask needed, rather than a duplicate TrainingRequirement table.
model CredentialType {
  id                String             @id @default(cuid())
  // Made unique in the V2.md Session 2 migration — discovered while adding upsert-based
  // seeding that this table had no unique constraint at all, so re-running `db:seed` was
  // silently duplicating every row indefinitely. FeedType/CareType/WorkType/MetricType have
  // the same latent gap; out of scope here (nothing in Session 2 touches them), flagged in
  // HANDOFF.md as a follow-up.
  name              String             @unique
  active            Boolean            @default(true)
  // Below: added for V2.md Session 2. isRequired/renewalPeriodDays drive the "expired or
  // missing required training" query; renewalPeriodDays null means one-time, never expires
  // (matches CONTEXT.md's rabies-vaccination-collected-for-legal-reasons-only case).
  isRequired        Boolean            @default(false)
  renewalPeriodDays Int?
  appliesToTier     HandlingColor?
  fileUrl           String?
  createdAt         DateTime           @default(now())
  records           CredentialRecord[]
}

model CredentialRecord {
  id               String         @id @default(cuid())
  volunteerId      String
  credentialTypeId String
  completedDate    DateTime
  expiresAt        DateTime?
  score            Int?
  fileRef          String?
  notes            String?
  notifiedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  volunteer        Volunteer      @relation(fields: [volunteerId], references: [id])
  credentialType   CredentialType @relation(fields: [credentialTypeId], references: [id])

  @@index([volunteerId])
  @@index([credentialTypeId])
  @@index([expiresAt])
}

// Formalizes the Green->Orange->Yellow->Blue progression (V2.md Session 2). Admin-editable
// data, not hardcoded constants, since exact thresholds are still approximate pending the
// real written schedule (CONTEXT.md §16). Tier is never cached on Volunteer — always computed
// at query time from firstShiftDate + this table (src/lib/tier.ts), per V2.md's explicit
// "don't store a cached current tier that can drift" instruction.
model TierThreshold {
  id                    String        @id @default(cuid())
  tier                  HandlingColor @unique
  minDaysTenure         Int
  requiresManualRelease Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([tier])
}

// Generic, extensible volunteer tagging (V2.md Session 3) — Go Team is the first real tag,
// but the schema doesn't assume it's the only one that will ever exist. Admin-managed lookup
// table, same category as Location/CredentialType/TierThreshold — not ChangeLog-tracked.
model VolunteerTag {
  id                      String                   @id @default(cuid())
  name                    String                   @unique
  description             String?
  // Threshold (in days since Volunteer.blueReleasedAt) for this tag's "eligibility
  // candidates" report — e.g. Go Team wants some additional tenure past Blue release, but
  // the exact number isn't settled yet, so it's admin-editable data here rather than a
  // hardcoded constant (V2.md's explicit instruction). Null means this tag has no
  // eligibility-candidates report configured (most tags won't need one — assignment is
  // always manual regardless).
  minDaysSinceBlueRelease Int?
  active                  Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  assignments             VolunteerTagAssignment[]
  gatedEvents             Event[]
}

// Append-ish (not append-only like AnimalLocationAssignment): assignment is a create,
// removal is an update setting removedAt/removedById rather than a delete — matches this
// project's general preference for closing a row over hard-deleting it (RegularShiftAssignment,
// MedicationRegimen), even though CLAUDE.md's explicit no-hard-delete list doesn't literally
// name this table. ChangeLog-tracked (unlike AnimalLocationAssignment) because, unlike that
// model, this one actually gets updated after creation — the removal itself is exactly the
// kind of field-level diff ChangeLog exists to capture.
model VolunteerTagAssignment {
  id           String       @id @default(cuid())
  volunteerId  String
  tagId        String
  assignedById String
  assignedAt   DateTime     @default(now())
  removedAt    DateTime?
  removedById  String?
  volunteer    Volunteer    @relation("VolunteerTagHolder", fields: [volunteerId], references: [id])
  tag          VolunteerTag @relation(fields: [tagId], references: [id])
  assignedBy   Volunteer    @relation("VolunteerTagAssignedBy", fields: [assignedById], references: [id])
  removedBy    Volunteer?   @relation("VolunteerTagRemovedBy", fields: [removedById], references: [id])

  @@index([volunteerId])
  @@index([tagId])
}

model RegularShiftAssignment {
  id          String    @id @default(cuid())
  volunteerId String
  dayOfWeek   Int
  shiftType   ShiftType
  active      Boolean   @default(true)
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([volunteerId])
  @@index([dayOfWeek, shiftType])
}

model Shift {
  id        String    @id @default(cuid())
  date      DateTime
  type      ShiftType
  // V2.md Session 5: per-occurrence override of ShiftTemplate's resolved start/end — "we
  // actually ran 15 minutes late today." "HH:MM" strings, same format as ShiftTemplate,
  // nullable (falls back to the template's resolved time when unset). Settable by a
  // SHIFT_LEAD or ADMIN for any occurrence — see setShiftActualTimes in
  // src/app/checkin/actions.ts. Who/when is captured by ChangeLog (Shift is tracked), not a
  // dedicated field on the row, same reasoning CONTEXT.md §10 gives for PastureAssignment.
  actualStartTime String?
  actualEndTime   String?
  createdAt DateTime  @default(now())
  checkIns  CheckIn[]

  @@unique([date, type])
}

// V2.md Session 5: singleton config row (enforced app-side via getFarmSettings() in
// src/lib/farmSettings.ts — findFirst-or-create, same "app-side simplicity over a DB
// constraint" preference as everything else admin-entered in this schema). A manual
// switch, not date-driven automation — farm staff decide when to flip it based on
// daylight/weather, per V2.md's explicit framing.
model FarmSettings {
  id           String     @id @default(cuid())
  activeSeason FarmSeason @default(STANDARD)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// V2.md Session 5: reference times for the two real shift occurrences a day. shiftType
// ties each template row directly to the existing ShiftType enum (AM/PM) — an addition
// beyond V2.md's literal field list, needed so a Shift's `type` can look up its matching
// template without a fragile match on `name`. Since ShiftType is a fixed two-value enum
// (CONTEXT.md §3: hard enums for things fixed by real-world logic), this table is
// necessarily capped at two rows — edit-only via /settings, no create/delete UI, same
// precedent as TierThreshold's fixed four rows. Not ChangeLog-tracked: admin-managed
// config/lookup data, same category as TierThreshold/Location, per CLAUDE.md's tracked-
// models list.
model ShiftTemplate {
  id                String    @id @default(cuid())
  name              String
  shiftType         ShiftType @unique
  // "HH:MM" 24-hour, no date component — plain strings round-trip cleanly through a native
  // <input type="time">, avoiding Prisma/Postgres @db.Time gymnastics for a value nothing
  // ever does arithmetic on (CLAUDE.md's "simplicity over cleverness" for a project meant
  // to stay maintainable by one person).
  standardStartTime String
  standardEndTime   String
  winterStartTime   String?
  winterEndTime     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model WorkType {
  id        String    @id @default(cuid())
  name      String
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  checkIns  CheckIn[]
}

model CheckIn {
  id             String       @id @default(cuid())
  volunteerId    String
  shiftId        String
  workTypeId     String
  checkInAt      DateTime
  checkOutAt     DateTime?
  checkInMethod  CheckMethod?
  checkOutMethod CheckMethod?
  loggedById     String?
  notes          String?
  createdAt      DateTime     @default(now())
  volunteer      Volunteer    @relation("VolunteerCheckIns", fields: [volunteerId], references: [id])
  shift          Shift        @relation(fields: [shiftId], references: [id])
  workType       WorkType     @relation(fields: [workTypeId], references: [id])
  loggedBy       Volunteer?   @relation("LoggedByVolunteer", fields: [loggedById], references: [id])

  @@index([volunteerId])
  @@index([shiftId])
  @@index([workTypeId])
  @@index([checkInAt])
}

model Animal {
  id                     String                     @id @default(cuid())
  name                   String
  species                AnimalSpecies              @default(HORSE)
  intakeDate             DateTime?
  status                 AnimalStatus               @default(ACTIVE)
  sex                    AnimalSex                  @default(UNKNOWN)
  spayed                 Boolean                    @default(false)
  legalCase              Boolean                    @default(false)
  caseReference          String?
  requiredHandlerColor   HandlingColor              @default(GREEN)
  handlingNotes          String?
  notes                  String?
  // V3.md Session 1: most animals arrive alone, so this stays nullable/optional rather than
  // required — set via the dedicated assignIntakeGroup action (Admin-or-Shift-Lead, same
  // "assignment" permission split as AnimalLocationAssignment), not the Admin-only
  // updateAnimal core-fields path, even though it lives directly on Animal.
  intakeGroupId          String?
  // V2.md Session 6: manual, admin-editable herd-hierarchy rank for the Turnout Board's
  // per-field ordering ("lead animal at top"). Nullable — most animals won't have a
  // documented rank, and null always sorts after any set value (see turnout-board/page.tsx),
  // falling back to alphabetical among unranked animals. Global per animal, not per-location,
  // matching the simplicity precedent set by Location.turnoutOrder/bringInOrder. Confirmed
  // with James (no such field/decision existed anywhere before this session, despite V2.md's
  // claim it had already been decided — see HANDOFF.md).
  herdOrder              Int?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  photos                 AnimalPhoto[]
  placements             Placement[]
  feedingBaselines       FeedingBaseline[]
  medicationRegimens     MedicationRegimen[]
  careEntries            CareEntry[]
  healthIssues           HealthIssue[]
  recurringCareSchedules RecurringCareSchedule[]
  metrics                AnimalMetric[]
  weightEntries          WeightEntry[]
  locationAssignments    AnimalLocationAssignment[]
  donations              DonationInKind[]
  intakeGroup            IntakeGroup?               @relation(fields: [intakeGroupId], references: [id])
  relationshipsFrom      AnimalRelationship[]       @relation("AnimalRelationshipFrom")
  relationshipsTo        AnimalRelationship[]       @relation("AnimalRelationshipTo")

  @@index([status])
  @@index([legalCase])
  @@index([intakeGroupId])
}

// V3.md Session 1: groups animals that physically arrived together (often thematically
// named — "Irish Group", a luxury-brand-named group), confirmed from the real Horse Care
// Board. Not ChangeLog-tracked — lookup-ish, same category as EventCategory, no legal-
// defensibility angle on the grouping fact itself (unlike AnimalRelationship, which records
// real bloodline claims).
model IntakeGroup {
  id         String   @id @default(cuid())
  label      String
  intakeDate DateTime
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  animals    Animal[]
}

// V3.md Session 1: one row per real-world relationship — the inverse (Rowan's sire is
// Guinness, derived from Guinness SIRE_OF Rowan) is computed at display time
// (src/lib/relationships.ts), never stored as a second row, so there's exactly one row to
// correct if a relationship claim turns out to be wrong. recordedById follows the
// AnimalLocationAssignment/EventSignup FK convention (a real Volunteer relation, not the
// older plain-string performedBy/recordedBy pattern on CareEntry/MedicationLog/WeightEntry/
// AnimalMetric) since this model is new as of this session. ChangeLog-tracked (confirmed
// with James) — a lineage claim on a legalCase animal sits on the same legal-defensibility
// surface as Animal itself (CONTEXT.md §4/§11).
model AnimalRelationship {
  id              String       @id @default(cuid())
  animalId        String
  relatedAnimalId String
  relationType    RelationType
  notes           String?
  recordedById    String
  createdAt       DateTime     @default(now())
  animal          Animal       @relation("AnimalRelationshipFrom", fields: [animalId], references: [id])
  relatedAnimal   Animal       @relation("AnimalRelationshipTo", fields: [relatedAnimalId], references: [id])
  recordedBy      Volunteer    @relation(fields: [recordedById], references: [id])

  @@index([animalId])
  @@index([relatedAnimalId])
}

model AnimalPhoto {
  id                String    @id @default(cuid())
  animalId          String
  url               String
  type              String
  isPrimary         Boolean   @default(false)
  takenAt           DateTime?
  uploadedBy        String?
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime  @default(now())
  animal            Animal    @relation(fields: [animalId], references: [id])

  @@index([animalId])
  @@index([relatedEntityType, relatedEntityId])
}

model Placement {
  id               String    @id @default(cuid())
  animalId         String
  adopterName      String
  adopterContact   String?
  placedDate       DateTime
  returnedDate     DateTime?
  followUpCadence  Int?
  nextFollowUpDate DateTime?
  notes            String?
  // V3.md Session 1: a shared token (not a new PlacementGroup table) across two or more
  // Placement rows created for the same real-world adoption event, so bonded animals placed
  // together are queryable as a set. Null for a normal single-animal placement.
  placementGroupId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  animal           Animal    @relation(fields: [animalId], references: [id])

  @@index([animalId])
  @@index([nextFollowUpDate])
  @@index([placementGroupId])
}

model FeedType {
  id          String            @id @default(cuid())
  name        String
  defaultUnit FeedUnit
  category    FeedCategory
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  baselines   FeedingBaseline[]
}

model FeedingBaseline {
  id              String            @id @default(cuid())
  animalId        String
  feedTypeId      String
  shift           ShiftType
  amount          Decimal           @db.Decimal(4, 2)
  requiresSoaking Boolean           @default(true)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  animal          Animal            @relation(fields: [animalId], references: [id])
  feedType        FeedType          @relation(fields: [feedTypeId], references: [id])
  overrides       FeedingOverride[]

  @@index([animalId])
  @@index([feedTypeId])
}

model FeedingOverride {
  id                String          @id @default(cuid())
  feedingBaselineId String
  date              DateTime
  amount            Decimal?        @db.Decimal(4, 2)
  reason            String?
  changedBy         String
  notes             String?
  createdAt         DateTime        @default(now())
  feedingBaseline   FeedingBaseline @relation(fields: [feedingBaselineId], references: [id])

  @@index([feedingBaselineId])
  @@index([date])
}

model MedicationRegimen {
  id        String          @id @default(cuid())
  animalId  String
  drugName  String
  dose      String
  route     String?
  frequency String
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  animal    Animal          @relation(fields: [animalId], references: [id])
  logs      MedicationLog[]

  @@index([animalId])
}

model MedicationLog {
  id                  String            @id @default(cuid())
  medicationRegimenId String
  date                DateTime
  administered        Boolean
  administeredBy      String
  notes               String?
  createdAt           DateTime          @default(now())
  medicationRegimen   MedicationRegimen @relation(fields: [medicationRegimenId], references: [id])

  @@index([medicationRegimenId])
  @@index([date])
}

model CareType {
  id                 String                  @id @default(cuid())
  name               String
  category           CareCategory
  active             Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  careEntries        CareEntry[]
  recurringSchedules RecurringCareSchedule[]
}

model CareEntry {
  id                   String       @id @default(cuid())
  animalId             String
  careTypeId           String
  date                 DateTime
  notes                String?
  performedBy          String
  relatedHealthIssueId String?
  createdAt            DateTime     @default(now())
  animal               Animal       @relation(fields: [animalId], references: [id])
  careType             CareType     @relation(fields: [careTypeId], references: [id])
  healthIssue          HealthIssue? @relation(fields: [relatedHealthIssueId], references: [id])

  @@index([animalId])
  @@index([careTypeId])
  @@index([date])
  @@index([relatedHealthIssueId])
}

model HealthIssue {
  id           String      @id @default(cuid())
  animalId     String
  description  String
  startDate    DateTime
  resolvedDate DateTime?
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  animal       Animal      @relation(fields: [animalId], references: [id])
  careEntries  CareEntry[]

  @@index([animalId])
  @@index([active])
}

model RecurringCareSchedule {
  id                String    @id @default(cuid())
  animalId          String
  careTypeId        String
  cadenceDays       Int?
  lastCompletedDate DateTime?
  nextDueDate       DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  animal            Animal    @relation(fields: [animalId], references: [id])
  careType          CareType  @relation(fields: [careTypeId], references: [id])

  @@index([animalId])
  @@index([nextDueDate])
}

model MetricType {
  id        String         @id @default(cuid())
  name      String
  unit      String
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  metrics   AnimalMetric[]
}

model AnimalMetric {
  id           String     @id @default(cuid())
  animalId     String
  metricTypeId String
  value        Decimal    @db.Decimal(4, 1)
  date         DateTime
  recordedBy   String
  notes        String?
  createdAt    DateTime   @default(now())
  animal       Animal     @relation(fields: [animalId], references: [id])
  metricType   MetricType @relation(fields: [metricTypeId], references: [id])

  @@index([animalId])
  @@index([metricTypeId])
  @@index([date])
}

model WeightEntry {
  id         String        @id @default(cuid())
  animalId   String
  date       DateTime
  weight     Decimal       @db.Decimal(6, 1)
  context    WeightContext @default(ROUTINE)
  recordedBy String
  notes      String?
  createdAt  DateTime      @default(now())
  animal     Animal        @relation(fields: [animalId], references: [id])

  @@index([animalId])
  @@index([date])
}

// Generalized (V2.md Session 1) from the Phase-1 Field-only model to also cover barn
// stalls, sick bay, and the covered arena. `fieldCode`/`turnoutOrder`/`bringInOrder`/
// `boundaryPoints` stay FIELD-specific (nullable, unused by other types); `barnNumber`/
// `stallNumber` are BARN_STALL-specific. Validated per-type at the Server Action layer,
// not via a DB constraint (matches this project's general preference for app-side checks
// over fighting Postgres for rarely-changing admin-entered data).
model Location {
  id             String                     @id @default(cuid())
  type           LocationType               @default(FIELD)
  name           String
  fieldCode      String?                    @unique
  barnNumber     Int?
  stallNumber    Int?
  boundaryPoints Json?
  turnoutOrder   Int?
  bringInOrder   Int?
  isActive       Boolean                    @default(true)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  assignments    AnimalLocationAssignment[]

  @@index([type])
}

// Append-only (V2.md Session 1): a move is always a new row, never an update to an old
// one. "Current location" for an animal+period is derived as the latest `effectiveAt` row
// for that pair — there is deliberately no stored "current" pointer that could drift.
// Not a ChangeLog-tracked model: unlike the `PastureAssignment` it replaces (which relied
// on ChangeLog to capture who/when since the row itself didn't), this row captures
// `recordedById`/`effectiveAt` directly — same reasoning CLAUDE.md already gives for why
// `AnimalPhoto` sits outside the tracked-models list.
model AnimalLocationAssignment {
  id           String         @id @default(cuid())
  animalId     String
  locationId   String
  period       LocationPeriod @default(DAY)
  effectiveAt  DateTime
  recordedById String
  notes        String?
  createdAt    DateTime       @default(now())
  animal       Animal         @relation(fields: [animalId], references: [id])
  location     Location       @relation(fields: [locationId], references: [id])
  recordedBy   Volunteer      @relation(fields: [recordedById], references: [id])

  @@index([animalId, period, effectiveAt])
  @@index([locationId])
}

model DonationInKind {
  id              String   @id @default(cuid())
  item            String
  donor           String?
  dateReceived    DateTime
  linkedAnimalId  String?
  linkedProjectId String?
  notes           String?
  createdAt       DateTime @default(now())
  animal          Animal?  @relation(fields: [linkedAnimalId], references: [id])

  @@index([linkedAnimalId])
}

// V2.md Session 4: replaces the manual email-tracking process with self-service signup.
// Admin-editable lookup, same category as WorkType/FeedType/Location — not ChangeLog-tracked.
model EventCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  events    Event[]
}

// Not ChangeLog-tracked: unlike Animal/Volunteer/CheckIn, nothing here carries a legal-
// defensibility requirement (CONTEXT.md §4) — same reasoning already given for Location and
// the other admin-managed/scheduling data in this schema.
// Gating (requiredTagId/requiredTier) is enforced app-side at both listing time (hidden from
// ineligible volunteers) and signup time (rejected server-side even on a direct action call)
// — see src/lib/events.ts. When both are set, a volunteer must satisfy both (AND), not either
// — the spec's only worked example (Blue Handler Class) sets just one, so this is this
// session's own interpretation, not a confirmed requirement; flagged in HANDOFF.md.
model Event {
  id                          String         @id @default(cuid())
  title                       String
  description                 String?
  categoryId                  String
  startAt                     DateTime
  endAt                       DateTime
  locationText                String?
  capacity                    Int?
  createdById                 String
  canceledAt                  DateTime?
  requiredTagId               String?
  requiredTier                HandlingColor?
  suppressSignupNotifications Boolean        @default(false)
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
  category                    EventCategory  @relation(fields: [categoryId], references: [id])
  createdBy                   Volunteer      @relation("EventCreatedBy", fields: [createdById], references: [id])
  requiredTag                 VolunteerTag?  @relation(fields: [requiredTagId], references: [id])
  watchers                    EventWatcher[]
  signups                     EventSignup[]

  @@index([categoryId])
  @@index([startAt])
  @@index([createdById])
}

// Additional people who get organizer-level notifications beyond the creator. Set at event
// creation time only (V2.md's own wording) — no add/remove-watcher action beyond that today.
model EventWatcher {
  id          String    @id @default(cuid())
  eventId     String
  volunteerId String
  createdAt   DateTime  @default(now())
  event       Event     @relation(fields: [eventId], references: [id])
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])

  @@unique([eventId, volunteerId])
  @@index([eventId])
}

// One row per volunteer per event — re-signing up after a cancellation flips the same row's
// status back rather than inserting a duplicate, so capacity/waitlist counts never have to
// dedupe across historical rows. signedUpAt is refreshed on re-signup so waitlist promotion
// order (earliest signedUpAt first, src/app/events/[id]/signup-actions.ts) reflects the
// current queue position, not a stale original attempt.
model EventSignup {
  id          String            @id @default(cuid())
  eventId     String
  volunteerId String
  status      EventSignupStatus @default(CONFIRMED)
  signedUpAt  DateTime          @default(now())
  canceledAt  DateTime?
  event       Event             @relation(fields: [eventId], references: [id])
  volunteer   Volunteer         @relation(fields: [volunteerId], references: [id])

  @@unique([eventId, volunteerId])
  @@index([eventId])
  @@index([volunteerId])
  @@index([status])
}

model ChatChannel {
  id        String          @id @default(cuid())
  type      ChatChannelType
  name      String
  createdAt DateTime        @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  channelId String
  senderId  String
  body      String
  createdAt DateTime    @default(now())
  channel   ChatChannel @relation(fields: [channelId], references: [id])
  sender    Volunteer   @relation(fields: [senderId], references: [id])

  @@index([channelId])
  @@index([senderId])
}

model ChangeLog {
  id         String          @id @default(cuid())
  entityType String
  entityId   String
  field      String?
  oldValue   String?
  newValue   String?
  changedBy  String
  note       String?
  action     ChangeLogAction
  createdAt  DateTime        @default(now())

  @@index([entityType, entityId])
  @@index([changedBy])
  @@index([createdAt])
}
