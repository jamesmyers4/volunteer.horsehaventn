{
  "name": "volunteer-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:migrate": "dotenv -e .env.test -- prisma migrate deploy",
    "test:db:seed": "dotenv -e .env.test -- tsx prisma/seed.ts",
    "test:db:reset": "npm run test:db:up && npm run test:db:migrate && npm run test:db:seed",
    "test:unit": "dotenv -e .env.test -- vitest run",
    "test:unit:watch": "dotenv -e .env.test -- vitest",
    "test:e2e": "dotenv -e .env.test -e .env -- playwright test",
    "test:all": "npm run test:db:reset && npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@clerk/nextjs": "^7.5.18",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@clerk/backend": "^3.11.7",
    "@clerk/testing": "^2.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "aws-sdk-client-mock": "^4.1.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
